GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# At least 32 characters; used for cookie signing and encrypting the API key in DB (Settings > Agent)
ENCRYPTION_KEY=change-me-to-a-long-random-string-at-least-32-chars
PORT=3000
PUBLIC_HOST=http://localhost:5173

# Data directory for SQLite DB, repo clones, and worktrees (default: ~/.baguette)
DATA_DIR=./.data
