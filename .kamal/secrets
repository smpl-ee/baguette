# Secrets are read from environment variables.
# For local deploys, set them in .kamal/.env (gitignored — see .kamal/.env.example).
# In CI (GitHub Actions), they are provided as secrets/variables.

GITHUB_CLIENT_ID=$GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=$GITHUB_CLIENT_SECRET
ENCRYPTION_KEY=$ENCRYPTION_KEY
DEPLOY_SERVER=$DEPLOY_SERVER
DEPLOY_USER=$DEPLOY_USER
DOMAIN=$DOMAIN
CERTIFICATE_PEM=$(ssh ${DEPLOY_USER}@${DEPLOY_SERVER} "cat /home/${DEPLOY_USER}/.acme.sh/${DOMAIN}_ecc/${DOMAIN}.cer")
PRIVATE_KEY_PEM=$(ssh ${DEPLOY_USER}@${DEPLOY_SERVER} "cat /home/${DEPLOY_USER}/.acme.sh/${DOMAIN}_ecc/${DOMAIN}.key")
