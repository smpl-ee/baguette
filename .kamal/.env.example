# Copy this file to .kamal/.env and fill in your values for local Kamal deploys.
# .kamal/.env is gitignored — never commit it.

# Your server's hostname or IP address
DEPLOY_SERVER=your-server-ip-or-hostname

# SSH user on the deploy server (default: ubuntu)
DEPLOY_USER=ubuntu

# Your domain (e.g. baguette.example.com — used for www.<DOMAIN>, *.<DOMAIN>, and acme.sh cert paths)
DOMAIN=your-domain.com

# GitHub OAuth App credentials
GITHUB_CLIENT_ID=xxxx
GITHUB_CLIENT_SECRET=xxxx

# At least 32 random characters — used for cookie signing and secret encryption
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
