{
  "name": "baguette",
  "version": "0.0.1",
  "description": "Self-hosted Claude Code agent sessions on GitHub repo worktrees",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"VITE_SERVER_ENABLED=true npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "NODE_ENV=development node --watch server/index.js",
    "dev:client": "npm run dev --prefix client",
    "install:all": "\"$npm_execpath\" install && cd client && \"$npm_execpath\" install",
    "build": "npm run build --prefix client",
    "start": "NODE_ENV=production node server/index.js",
    "migrate": "knex migrate:latest --knexfile knexfile.js",
    "migrate:make": "knex migrate:make --knexfile knexfile.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@feathersjs/errors": "^5.0.41",
    "@feathersjs/express": "^5.0.41",
    "@feathersjs/feathers": "^5.0.41",
    "@feathersjs/knex": "^5.0.41",
    "@feathersjs/socketio": "^5.0.41",
    "better-sqlite3": "latest",
    "cookie": "^1.1.1",
    "cookie-parser": "latest",
    "cookie-signature": "latest",
    "dotenv": "latest",
    "ejs": "latest",
    "express": "latest",
    "js-yaml": "^4.1.1",
    "knex": "latest",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "ws": "latest"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "latest",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
